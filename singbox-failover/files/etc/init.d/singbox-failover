#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

start_service() {
	local enabled

	config_load singbox_failover
	config_get_bool enabled main enabled 0

	if [ "$enabled" != "1" ]; then
		logger -t singbox-failover "disabled in UCI; runtime is not started"
		/usr/bin/singbox-failover cleanup >/dev/null 2>&1
		return 0
	fi

	procd_open_instance
	procd_set_param command /usr/bin/singbox-failover daemon
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_close_instance
}

stop_service() {
	/usr/bin/singbox-failover cleanup >/dev/null 2>&1
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger singbox_failover
}

